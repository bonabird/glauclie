# Client environment — copy to client/.env for local dev

# Server-side — Go API for SSR and hooks
API_INTERNAL_URL=http://localhost:8080

# Public
PUBLIC_ALLOW_REGISTRATION=true

# Leave unset locally (Vite proxies /api to the Go API).
# Production (separated frontend + API):
# PUBLIC_API_URL=https://api.glaucidae.com
# API_INTERNAL_URL=https://api.glaucidae.com
# PUBLIC_ALLOW_REGISTRATION=false
